                      type="mesh" mesh="banana_visual" conaffinity="0" contype="0" group="2" material="banana_mat" />
                
                <!-- 碰撞几何体 -->
                <geom solimp="0.998 0.998 0.001" solref="0.001 1" density="100" friction="0.95 0.3 0.1" 
