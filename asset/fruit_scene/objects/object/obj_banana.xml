<mujoco model="obj_banana">
    <asset>
        <!-- 视觉网格 -->
        <mesh file="../mesh/obj_banana/visual/banana.obj" name="banana_visual" scale="1.2 1.2 1.2" refquat="0.7071067811865472 0.0 0.0 0.7071067811865476" />
        
        <!-- 碰撞网格 -->
        <mesh file="../mesh/obj_banana/collision/obj_banana0.obj" name="banana_collision_0" scale="1.2 1.2 1.2" refquat="0.7071067811865472 0.0 0.0 0.7071067811865476" />
